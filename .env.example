# ─────────────────────────────────────────────────────────────
# Netlify environment variables — copy to your Netlify dashboard
# under: Site settings → Environment variables
# ─────────────────────────────────────────────────────────────
# Do NOT commit actual keys. This file is a template only.

# ── Contact form (Resend) ─────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The inbox that receives portfolio contact messages
CONTACT_TO_EMAIL=slenderisprogramming@gmail.com

# The "From" address shown in the email.
# Must be a domain verified in Resend (or leave as the default below).
# Default used when unset: portfolio@resend.dev
CONTACT_FROM_EMAIL=portfolio@resend.dev

# Optional — fallback FormSubmit endpoint if Resend is not configured.
# Defaults to https://formsubmit.co/slenderisprogramming@gmail.com
# CONTACT_FALLBACK_URL=https://formsubmit.co/slenderisprogramming@gmail.com
